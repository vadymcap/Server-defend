{
  "name": "ServerDefendGamePlace",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "TS": {
        "$path": "out/shared"
      },
      "Assets": {
        "$className": "Folder"
      }
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$properties": {
        "CameraMode": "LockFirstPerson"
      },
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "TS": {
          "$path": "out/client"
        }
      },
      "StarterCharacterScripts": {
        "$className": "StarterCharacterScripts"
      }
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "TS": {
        "$path": "out/server"
      }
    },

    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "Gravity": 196.2,
        "StreamingEnabled": false,
        "CurrentCamera": {
          "$ref": "Workspace/Camera"
        }
      },
      "Grid": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "CanCollide": false,
          "Size": { "X": 120, "Y": 0.1, "Z": 120 },
          "Position": { "X": 0, "Y": -0.1, "Z": 0 },
          "Color": { "R": 0.07, "G": 0.07, "B": 0.07 },
          "Material": "SmoothPlastic",
          "CastShadow": false
        }
      }
    },

    "Lighting": {
      "$className": "Lighting",
      "$properties": {
        "Ambient": { "R": 0.3, "G": 0.3, "B": 0.35 },
        "Brightness": 1.2,
        "ClockTime": 14
      },
      "Atmosphere": {
        "$className": "Atmosphere",
        "$properties": {
          "Density": 0.1,
          "Haze": 0,
          "Glare": 0
        }
      }
    },

    "SoundService": {
      "$className": "SoundService",
      "GameBGM": {
        "$className": "Sound",
        "$properties": {
          "SoundId": "rbxassetid://0",
          "Volume": 0.2,
          "Looped": true
        }
      },
      "SfxSuccess": {
        "$className": "Sound",
        "$properties": {
          "SoundId": "rbxassetid://0",
          "Volume": 0.5
        }
      },
      "SfxFail": {
        "$className": "Sound",
        "$properties": {
          "SoundId": "rbxassetid://0",
          "Volume": 0.5
        }
      },
      "SfxPlace": {
        "$className": "Sound",
        "$properties": {
          "SoundId": "rbxassetid://0",
          "Volume": 0.4
        }
      },
      "SfxClick": {
        "$className": "Sound",
        "$properties": {
          "SoundId": "rbxassetid://0",
          "Volume": 0.3
        }
      }
    }
  }
}
